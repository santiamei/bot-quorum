# Copiá este archivo como .env y completá los valores.
# NUNCA subas .env al repo.

# API Key de Google Gemini (gratis en aistudio.google.com)
GEMINI_API_KEY=tu_clave_gemini_aqui

# Alertas por Telegram (gratis, instantáneo)
# Token: lo da @BotFather al crear el bot
# Chat ID: tu ID de usuario en Telegram
TELEGRAM_BOT_TOKEN=1234567890:ABCdef...
TELEGRAM_CHAT_ID=7802849976
