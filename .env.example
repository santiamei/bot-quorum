# Copiá este archivo como .env y completá los valores.
# NUNCA subas .env al repo.

# API Key de Google Gemini (gratis en aistudio.google.com)
GEMINI_API_KEY=tu_clave_gemini_aqui

# WhatsApp via CallMeBot (gratis)
# Activación: enviá "I allow callmebot to send me messages" al +34 644 97 46 14
# Recibirás tu API key por WhatsApp.
WHATSAPP_PHONE=+5491100000000   # Tu número con código de país, sin espacios
CALLMEBOT_API_KEY=tu_api_key_callmebot
